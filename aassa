<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Stream Site</title>
    <style>
        body { background: #0b0c10; color: #fff; font-family: sans-serif; padding: 20px; text-align: center; }
        video { width: 100%; max-width: 800px; background: #000; border-radius: 8px; margin-bottom: 20px;}
        .grid { display: flex; justify-content: center; gap: 20px; margin-top: 20px; }
        .card { background: #1f2833; padding: 15px; border-radius: 8px; cursor: pointer; width: 220px; }
        .card img { width: 100%; border-radius: 4px; }
    </style>
</head>
<body>
    <h1>My Streaming App</h1>
    <video id="player" controls><source src="" id="src"></video>
    <h2 id="title">Select a Movie Below</h2>
    <div class="grid" id="grid"></div>
    <script>
        async function load() {
            const res = await fetch('/api/movies');
            const movies = await res.json();
            document.getElementById('grid').innerHTML = movies.map(m => `
                <div class="card" onclick="play('${m.videoUrl}', '${m.title}')">
                    <img src="${m.thumbnail}">
                    <h3>${m.title}</h3>
                </div>
            `).join('');
        }
        function play(url, title) {
            document.getElementById('src').src = url;
            document.getElementById('player').load();
            document.getElementById('title').innerText = title;
            document.getElementById('player').play();
        }
        load();
    </script>
</body>
</html>
